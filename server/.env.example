# Copy to .env and fill in real values. Never commit .env.
PORT=4000
# Container maps to host port 5433 (5432 is taken by a native PostgreSQL on this machine)
DATABASE_URL="postgresql://petcrm:petcrm_dev@localhost:5433/petcrm"

# Auth (generate long random strings for real use)
# Pepper is mixed into every password hash (argon2 secret). Changing it
# invalidates ALL stored password hashes — guard it like a root credential.
PASSWORD_PEPPER=""
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# AI booking assistant (server-side only — never expose to the client).
# Free key + free model at openrouter.ai. Without a key the assistant is
# simply disabled (the chat widget hides itself).
OPENROUTER_API_KEY=""
# Any OpenRouter model id; default is a free one. Must support tool calling.
OPENROUTER_MODEL="openai/gpt-oss-20b:free"

# Email (Resend). MAIL_FROM needs a verified domain; the resend.dev sender works for dev.
RESEND_API_KEY=""
MAIL_FROM="Pet Grooming <onboarding@resend.dev>"

# LINE (scaffold — future)
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""

# Public web app origin used in email links
FRONTEND_URL=http://localhost:3000

# Login email 2FA: set to "false" to skip the OTP step (single-step login).
# When on, an emailed code is required after the password — needs RESEND_API_KEY.
LOGIN_OTP_ENABLED=true
# DEV ONLY: echo OTP codes in API responses so you can test without a real inbox.
# Double-gated (ignored unless NODE_ENV != production). NEVER set in production.
AUTH_DEV_ECHO_OTP=0
