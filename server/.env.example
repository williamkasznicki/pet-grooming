# Copy to .env and fill in real values. Never commit .env.
PORT=4000
# Container maps to host port 5433 (5432 is taken by a native PostgreSQL on this machine)
DATABASE_URL="postgresql://petcrm:petcrm_dev@localhost:5433/petcrm"

# Auth (generate long random strings for real use)
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# AI (server-side only — never expose to the client)
OPENROUTER_API_KEY=""

# Email
RESEND_API_KEY=""

# LINE (scaffold — future)
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""
